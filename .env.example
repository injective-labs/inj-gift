# Stack Mode (auto|evm|wasm)
NEXT_PUBLIC_STACK_MODE=evm

# Network Configuration
NEXT_PUBLIC_NETWORK=testnet

# Injective Network Endpoints
NEXT_PUBLIC_LCD_ENDPOINT=https://testnet.lcd.injective.network
NEXT_PUBLIC_RPC_ENDPOINT=https://testnet.rpc.injective.network
NEXT_PUBLIC_CHAIN_ID=injective-888

# EVM Configuration
NEXT_PUBLIC_EVM_CHAIN_ID=1439
NEXT_PUBLIC_EVM_RPC_URL=https://k8s.testnet.json-rpc.injective.network/
NEXT_PUBLIC_EVM_CONTRACT_ADDRESS=0xfF2750Ac6f03d4fD4AA19D49a17DC4459cf2d6Ed

# INJ Pass embedded wallet (@injpass/cli)
# Points at the deployed inj-pass-frontend /embed route. Enables the
# "INJ Pass" wallet option (passkey-secured, no extension needed).
# Dev: http://localhost:3001/embed   Prod: https://<inj-pass-domain>/embed
NEXT_PUBLIC_INJPASS_EMBED_URL=https://www.injpass.com/embed

# Optional: WalletConnect Configuration
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here
# NEXT_PUBLIC_APP_URL=https://your-app-url.vercel.app
# NEXT_PUBLIC_APP_ICON_URL=https://your-app-url.vercel.app/favicon.ico
