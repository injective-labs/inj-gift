# Stack Mode (auto|evm|wasm)
NEXT_PUBLIC_STACK_MODE=evm

# Network Configuration
NEXT_PUBLIC_NETWORK=mainnet

# Injective Network Endpoints
NEXT_PUBLIC_LCD_ENDPOINT=https://sentry.lcd.injective.network
NEXT_PUBLIC_RPC_ENDPOINT=https://sentry.tm.injective.network
NEXT_PUBLIC_CHAIN_ID=injective-1

# EVM Configuration
NEXT_PUBLIC_EVM_CHAIN_ID=1776
NEXT_PUBLIC_EVM_RPC_URL=https://sentry.evm-rpc.injective.network/
NEXT_PUBLIC_EVM_CONTRACT_ADDRESS=0x5373A185ee8017eeDD8bF51C009f5A1F058A8D02

# Server-only packet persistence. Never prefix this with NEXT_PUBLIC_.
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true

# Optional server-only overrides. If omitted, the API uses the matching
# NEXT_PUBLIC_EVM_* chain configuration above.
# GIFT_EVM_CHAIN_ID=1776
# GIFT_EVM_RPC_URL=https://sentry.evm-rpc.injective.network/
# GIFT_EVM_CONTRACT_ADDRESS=0x5373A185ee8017eeDD8bF51C009f5A1F058A8D02

# INJ Pass embedded wallet (@injpass/cli)
# Points at the deployed inj-pass-frontend /embed route. Enables the
# "INJ Pass" wallet option (passkey-secured, no extension needed).
# Dev: http://localhost:3001/embed   Prod: https://<inj-pass-domain>/embed
NEXT_PUBLIC_INJPASS_EMBED_URL=https://www.injpass.com/embed

# Server-only gasless claim Relayer. Never prefix these with NEXT_PUBLIC_.
INJ_GIFT_RELAYER_PRIVATE_KEY=0xc216e2a05e89759b48e437791eae9a90cfca8d7c8ca1378d4c2877300c54869c
INJ_GIFT_CONTRACT_ADDRESSES=0x5373A185ee8017eeDD8bF51C009f5A1F058A8D02
INJ_GIFT_RELAYER_MAX_GAS=500000

# Mini app deployment. INJ Pass registers this exact origin and embeds it as an
# isolated iframe; production onboarding assigns the `gift.injpass.com` prefix.
NEXT_PUBLIC_APP_URL=https://gift.injpass.com
NEXT_PUBLIC_APP_ICON_URL=https://gift.injpass.com/favicon.ico

# Optional: WalletConnect Configuration
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here
